# Server
PORT=3000
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

# Database (Railway PostgreSQL — use separate instances for dev and prod)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_NAME=sow

# Auth
JWT_SECRET=
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth (optional one-click sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Monnify (BE2 — sandbox credentials from the Monnify developer dashboard)
MONNIFY_ENV=SANDBOX
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_WALLET_ACCOUNT_NUMBER=

# LLM — OpenAI-compatible endpoint (local Ollama in dev, Ollama Cloud in prod)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=

# Mail (email OTP verification via Plunk)
PLUNK_API_KEY=
